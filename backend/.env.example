# ------------------------------
# Server Configuration
# ------------------------------
SERVER_PORT=5001
NODE_ENV=development
# NODE_ENV=production
# For Production

# ------------------------------
# Backend URLs
# ------------------------------
BACKEND_LOCAL_URL=http://localhost:5001
BACKEND_SERVER_URL=https://api-campus-connect.example.com

# ------------------------------
# Database Configuration
# ------------------------------
# Use ONE of the following approaches:
# 1) Standard Prisma/Postgres: set DATABASE_URL only
# 2) Prisma Accelerate: DATABASE_URL=prisma+postgres://... and DIRECT_URL=postgresql://...
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/campus_connect
DIRECT_URL=

# Slow query logging threshold in ms (minimum enforced: 100)
SLOW_QUERY_THRESHOLD_MS=250

# DB guard settings
# DB_CALL_TIMEOUT_MS minimum: 1000
# DB_BREAKER_FAILURE_THRESHOLD minimum: 2
# DB_BREAKER_COOLDOWN_MS minimum: 5000
DB_CALL_TIMEOUT_MS=7000
DB_BREAKER_FAILURE_THRESHOLD=5
DB_BREAKER_COOLDOWN_MS=30000

# ------------------------------
# Authentication
# ------------------------------
# Use a strong random secret in production.
JWT_SECRET=replace_with_a_long_random_secret

# Token expiration time (examples: 30m, 1h, 7d)
JWT_EXPIRES_IN=7d

# ------------------------------
# Cache (Optional)
# ------------------------------
# If set, Redis is used for SWR cache. If empty, in-memory cache is used.
REDIS_URL=redis://localhost:6379

# Events API cache controls (all in ms)
# CACHE_TTL_* minimum: 30000
# CACHE_STALE_* minimum: corresponding CACHE_TTL_* value
CACHE_TTL_HOME_MS=60000
CACHE_TTL_EVENTS_MS=45000
CACHE_TTL_SEARCH_MS=30000
CACHE_STALE_HOME_MS=120000
CACHE_STALE_EVENTS_MS=90000
CACHE_STALE_SEARCH_MS=60000

# Home sections refresh scheduler
# HOME_SECTION_REFRESH_MS clamped to [60000, 300000]
# HOME_SECTION_LIMIT is clamped internally to <= 120
HOME_SECTION_REFRESH_MS=60000
HOME_SECTION_LIMIT=120

# ------------------------------
# Alerts + Health Monitor (Optional)
# ------------------------------
# If empty, alert webhook sending is disabled.
ALERT_WEBHOOK_URL=

# Health monitor target URL fallback order:
# MONITOR_TARGET_URL -> BACKEND_SERVER_URL -> BACKEND_LOCAL_URL -> http://localhost:5001
MONITOR_TARGET_URL=

# Health monitor timing in ms
# HEALTH_CHECK_INTERVAL_MS minimum: 15000
# HEALTH_CHECK_TIMEOUT_MS minimum: 1000
HEALTH_CHECK_INTERVAL_MS=30000
HEALTH_CHECK_TIMEOUT_MS=5000
